# Copy this file to .env and fill in the values
# cp .env.example .env

# Web UI access token (required) — generate with: openssl rand -hex 32
ACCESS_TOKEN=

# Session signing secret (required) — generate with: openssl rand -hex 32
JWT_SECRET=

# Node environment
NODE_ENV=production

# API port
PORT=3000

# SQLite database path (inside the Docker volume)
DB_PATH=/data/clawswarm.db

# WebSocket heartbeat (milliseconds)
WS_HEARTBEAT_INTERVAL=25000
WS_HEARTBEAT_TIMEOUT=30000
